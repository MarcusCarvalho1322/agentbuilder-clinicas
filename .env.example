# AgentBuilder.IA — Variáveis de Ambiente
# Copie para .env.local e preencha os valores

# Banco de dados Neon
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/agentbuilder?sslmode=require

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Autenticação do painel admin
ADMIN_SECRET=sua-senha-admin-super-secreta-aqui

# URL base da aplicação
NEXT_PUBLIC_APP_URL=https://agentbuilder-clinicas.vercel.app

# N8N - webhook para notificações
N8N_WEBHOOK_COMPLETED=https://seu-n8n.railway.app/webhook/onboarding-completed
N8N_WEBHOOK_NEW=https://seu-n8n.railway.app/webhook/onboarding-new
